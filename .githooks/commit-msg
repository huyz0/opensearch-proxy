#!/usr/bin/env bash
# Validates the commit subject format and the Co-Authored-By trailer.
# See .agents/skills/git-workflow/SKILL.md.
set -euo pipefail

msg_file="$1"
subject="$(head -n1 "$msg_file")"

# Allow merge/revert commits through unchanged.
if printf '%s' "$subject" | grep -qE '^(Merge|Revert) '; then
  exit 0
fi

pattern='^(feat|fix|docs|test|chore|refactor|perf|build|ci)(\([a-z0-9-]+\))?: [a-z].*'
if ! printf '%s' "$subject" | grep -qE "$pattern"; then
  echo "commit-msg: subject must be 'type(scope): lowercase description'" >&2
  echo "  type ∈ feat|fix|docs|test|chore|refactor|perf|build|ci" >&2
  echo "  got: $subject" >&2
  exit 1
fi

if ! grep -q '^Co-Authored-By: ' "$msg_file"; then
  echo "commit-msg: missing 'Co-Authored-By:' trailer" >&2
  exit 1
fi
